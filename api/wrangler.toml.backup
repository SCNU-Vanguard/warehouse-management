FEISHU_WIKI_TOKEN = "JPtgwwj0mia1KvkOOoUckEGOngd"
FEISHU_SHEET_ID = "81kyme"
FEISHU_ITEMS_TABLE_ID = "tblMsuzoJ3m3eXfw"
ALLOWED_ORIGIN = "https://scnu-vanguard.github.io"

FIELD_CODE = "货物编号"
